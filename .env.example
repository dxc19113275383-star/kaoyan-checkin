# ===== 环境变量示例 =====
# 复制为 .env（本地）或在 Netlify 后台 Site settings → Environment variables 中配置。
# 不要把真实密钥提交进仓库。.env 已在 .gitignore 中忽略。

# ----- DeepSeek / AI -----
# 仅在 Netlify Functions（服务端）使用，绝不要暴露到前端。
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ----- Web Push VAPID -----
# 用 `npx web-push generate-vapid-keys` 生成。公钥可下发前端，私钥只留服务端。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ----- Netlify（可选，CI / CLI 部署用）-----
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=

# ----- App（前端可见，VITE_ 前缀会被打进构建产物，勿放密钥）-----
VITE_APP_NAME=Kaoyan Check-in
VITE_APP_VERSION=7.0.0
